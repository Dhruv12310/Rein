# Rein environment. Copy this to .env.local and fill in real values.
# .env.local is gitignored. Never commit real credentials.

# Region the Aurora DSQL cluster lives in, for example us-east-1.
AWS_REGION=

# The DSQL cluster endpoint hostname, for example:
# abcd1234efgh5678.dsql.us-east-1.on.aws
DSQL_CLUSTER_ENDPOINT=

# AWS credentials used to mint the short-lived IAM auth token for DSQL.
# Locally these can also come from the AWS credentials file or an attached role
# instead of being set here. On Vercel, set them as project environment variables.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Only needed for temporary credentials (assumed roles, SSO).
AWS_SESSION_TOKEN=

# Optional. Defaults are the postgres database and the admin user.
DSQL_DATABASE=postgres
DSQL_USER=admin

# Optional. IAM token lifetime in seconds. DSQL default is 900, max 3600.
DSQL_TOKEN_EXPIRY_SECONDS=900
